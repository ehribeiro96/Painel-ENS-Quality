# HermesOps HML example environment
# Do not put real secrets in this file.
# Copy to .env.hml locally only after human approval.

COMPOSE_PROJECT_NAME=hermesops_hml

POSTGRES_DB=hermesops_hml
POSTGRES_USER=hermesops
POSTGRES_PASSWORD=CHANGE_ME_DO_NOT_COMMIT

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_PORT=6333

COMPOSIO_ENABLED=false
COMPOSIO_MODE=read-only
COMPOSIO_API_KEY=DO_NOT_COMMIT_REAL_VALUE
