{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Modding Project",
  "type": "object",
  "required": [
    "project_name",
    "allowed_actions",
    "forbidden_actions",
    "compatibility",
    "validation"
  ],
  "properties": {
    "project_name": {
      "type": "string"
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "compatibility": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
