{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Toolchain Profile",
  "type": "object",
  "required": [
    "stack",
    "build_commands",
    "test_commands",
    "lint_commands"
  ],
  "properties": {
    "stack": {
      "type": "string"
    },
    "build_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lint_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
