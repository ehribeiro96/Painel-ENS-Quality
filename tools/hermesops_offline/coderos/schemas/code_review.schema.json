{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code Review",
  "type": "object",
  "required": [
    "summary",
    "findings",
    "risk",
    "recommendation"
  ],
  "properties": {
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "string"
    },
    "recommendation": {
      "type": "string"
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
