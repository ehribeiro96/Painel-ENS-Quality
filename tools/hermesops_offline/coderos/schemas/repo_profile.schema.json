{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Repo Profile",
  "type": "object",
  "required": [
    "repo_path",
    "stack_tags",
    "risk_tags",
    "entrypoints"
  ],
  "properties": {
    "repo_path": {
      "type": "string"
    },
    "stack_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
