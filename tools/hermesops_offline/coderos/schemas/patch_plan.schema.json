{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Patch Plan",
  "type": "object",
  "required": [
    "objective",
    "files",
    "changes",
    "validation",
    "rollback"
  ],
  "properties": {
    "objective": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "string"
    }
  }
}
