
# =============================================
# Arquivo de exemplo de variáveis de ambiente
# =============================================
# Copie este arquivo para `.env` na raiz do projeto ou na pasta `ops/` e
# ajuste os valores conforme o ambiente (desenvolvimento, homologação, produção).
# Nenhuma destas variáveis é obrigatória, mas elas permitem controlar:
#   - Caminho do banco (`ENS_DB_PATH`)
#   - Modo de aplicação (admin x público) (`ENS_APP_MODE`)
#   - Integração com Microsoft Graph
#   - Envio de e-mails via SMTP em modo híbrido
# =============================================

# ==== Configuração ENS (copie para .env e ajuste) ====
ENS_SECRET_KEY=troque-por-uma-chave-forte

# Microsoft Entra (Azure AD)
ENS_MS_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENS_MS_CLIENT_SECRET=coloque_o_segredo_aqui
ENS_MS_TENANT_ID=00000000-0000-0000-0000-000000000000
ENS_MS_REQUIRED_GROUP_IDS=

# Banco (deixe vazio para usar ./data/ens.db)
ENS_DB_PATH=

# Host/Port
ENS_HOST=0.0.0.0
ENS_PORT=8080
# Hot reload local (FastAPI)
#ENS_RELOAD=1

# Caminho alternativo para o build do React (se nao usar frontend_dist/)
#FRONTEND_DIST=/caminho/para/dist


# -----------------------------
# Envio híbrido de e-mails SMTP
# -----------------------------
# Define se o portal deve usar SMTP ao invés de Microsoft Graph.
# Valores possíveis:
#   ON  -> força envio via SMTP
#   OFF -> usa Microsoft Graph (padrão em produção)
#ENS_SMTP_MODE=ON

# Servidor SMTP utilizado para envio em homologação
#ENS_SMTP_HOST=smtp.office365.com
#ENS_SMTP_PORT=587

# Credenciais da conta de envio em homologação
# (NÃO use credenciais sensíveis em repositórios Git ou prints de tela)
#ENS_SMTP_USER=esttevao.henrique@hotmail.com
#ENS_SMTP_PASSWORD=<SMTP_PASSWORD_REDACTED>

# Hero publico (liga/desliga)
# Valores: ON, OFF (padrao OFF)
#ENS_PUBLIC_HERO_ENABLED=ON
