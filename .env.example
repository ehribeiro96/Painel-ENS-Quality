APP_NAME=ENS ITAM Platform
ENVIRONMENT=local
APP_HOST=127.0.0.1
APP_PORT=8080
ENS_BUILD_FRONTEND=auto
DATABASE_URL=postgresql+asyncpg://itam:itam@postgres:5432/itam
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=<GERAR_SECRET_FORTE_COM_32_OU_MAIS_CARACTERES>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
ALLOWED_ORIGINS=
UPLOAD_MAX_MB=25
IMPORT_MAX_ROWS=10000
APP_STARTUP_CHECKS=true
APP_AUTO_MIGRATE=true
DEPENDENCY_RETRY_ATTEMPTS=30
DEPENDENCY_RETRY_DELAY_SECONDS=2
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<DEFINIR_LOCALMENTE_COM_10_OU_MAIS_CARACTERES>
ADMIN_NAME=Administrador
RATE_LIMIT_PER_MINUTE=240
AUTH_RATE_LIMIT_PER_MINUTE=20
VITE_API_URL=
ENABLE_AI_CHAT=false
AI_CHAT_DEFAULT_PROVIDER=mock
AI_CHAT_PROVIDER=mock
AI_PROVIDER=mock
AI_MODEL=
AI_GEMINI_API_KEY=
AI_OPENAI_API_KEY=
AI_TIMEOUT_SECONDS=30
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=1000
AI_CHAT_RATE_LIMIT_PER_MINUTE=20
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b-64k
OLLAMA_ALLOWED_HOSTS=localhost,127.0.0.1,::1
OLLAMA_TIMEOUT_SECONDS=60
HERMES_BASE_URL=
HERMES_MODEL=hermes-agent

# AI Chat via Ollama LAN OpenAI-compatible (B5-B)
